# Emacs configuration .gitignore
# Only track core config files, ignore all generated/installed content

# =============================================================================
# Package Management (straight.el)
# =============================================================================
# These are auto-generated/downloaded on first run, except the version lockfile:
# it pins every package to an exact commit so all machines install the same
# tree.  Without it Straight floats each package independently, which lets a
# dependency drift out of sync with its dependents (e.g. Vertico requiring a
# newer Compat than the one checked out) and breaks completion.
straight/*
!straight/versions/

# =============================================================================
# Native Compilation Cache (Emacs 29+)
# =============================================================================
eln-cache/

eshell/

# =============================================================================
# Emacs Generated Files
# =============================================================================
# Auto-save files
\#*\#
.\#*

# Backup files
*~
*.bak

# Lock files
.#*

# Custom file (set by Emacs, can contain machine-specific settings)
custom.el

# Desktop save files
.emacs.desktop
.emacs.desktop.lock

# Session files
session.*
auto-save-list/

# =============================================================================
# History & Cache
# =============================================================================
recentf
history
places
bookmarks
ido.last
tramp
url/
transient/
projectile-bookmarks.eld
projectile.cache
.lsp-session*
.cache/

# Forge PR/issue metadata cache (local SQLite; never commit or migrate)
forge-database.sqlite*

# =============================================================================
# Perspective/Workspace State
# =============================================================================
persp-confs/
persp-auto-save

# =============================================================================
# TRAMP
# =============================================================================
tramp-autosave/

# =============================================================================
# Compiled Elisp
# =============================================================================
*.elc

# =============================================================================
# Tree-sitter Grammars (auto-downloaded)
# =============================================================================
tree-sitter/

# =============================================================================
# Old/Backup Config (from refactoring)
# =============================================================================
*.el.bak

# =============================================================================
# OS Generated Files
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Secrets & OAuth Tokens
# =============================================================================
# OAuth token store (contains access/refresh tokens)
oauth2-auto.plist

# Local secrets file (OAuth client ID/secret)
secrets.el

# =============================================================================
# Org-mode State Files
# =============================================================================
# Org ID tracking (machine-specific)
.org-id-locations
.org-generic-id-locations

# Clock persistence
org-clock-save.el

# org-gcal / org-persist state
persist/

# HTTP request cookies
request/

# =============================================================================
# Editor Files
# =============================================================================
.vscode/
.idea/
